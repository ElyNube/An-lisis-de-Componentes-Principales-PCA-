    {
      "cell_type": "markdown",
      "source": [
        "##3.3.Grafica MSE vs número de componentes y MSE vs ratio de compresión."
      ],
      "metadata": {
        "id": "n_i8dv48COFU"
      },
      "id": "n_i8dv48COFU"
    },
    {
      "cell_type": "code",
      "source": [
        "# ================================\n",
        "#  GRÁFICOS DE ANÁLISIS\n",
        "# ================================\n",
        "\n",
        "# Gráfico 1: MSE versus número de componentes.\n",
        "plt.figure(figsize=(8, 5))\n",
        "plt.plot(tabla_resultados[\"k\"], tabla_resultados[\"MSE\"], marker=\"o\")\n",
        "\n",
        "#Para agregar las etiquetas \"k=...\"\n",
        "for i in range(len(tabla_resultados)):\n",
        "    # Extraemos los valores de la fila actual\n",
        "    k_val = int(tabla_resultados[\"k\"].iloc[i])\n",
        "    x_val = tabla_resultados[\"k\"].iloc[i]\n",
        "    y_val = tabla_resultados[\"MSE\"].iloc[i]\n",
        "\n",
        "# Colocamos la anotación desplazada un poco (xytext=(5, 5)) para que no tape el punto\n",
        "    plt.annotate(f\"k={k_val}\", (x_val, y_val), textcoords=\"offset points\", xytext=(5, 5), fontsize=9)\n",
        "\n",
        "plt.title(\"MSE vs número de componentes\")\n",
        "plt.xlabel(\"Número de componentes (k)\")\n",
        "plt.ylabel(\"MSE\")\n",
