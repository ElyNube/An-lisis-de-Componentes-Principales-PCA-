        "plt.axis('off')\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# Verificación de dimensiones para el informe\n",
        "print(f\"Dimensiones de la reconstrucción: {X_hat.shape}\")"
      ],
