        "# 1. Aplicamos la fórmula de reconstrucción: (Z * V^T) + media\n",
        "# Usamos los 5 componentes (Z5 y V5) que calculamos anteriormente\n",
        "X_hat = (Z5 @ V5.T) + mu\n",
        "\n",
        "# 2. Creamos la visualización para comparar\n",
        "plt.figure(figsize=(10, 5))\n",
        "\n",
        "# Imagen Original\n",
        "plt.subplot(1, 2, 1)\n",
        "plt.imshow(imagen_camera, cmap='gray')\n",
