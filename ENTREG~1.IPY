7421875,\n        \"max\": 95.8984375,\n        \"num_unique_values\": 3,\n        \"samples\": [\n          95.8984375,\n          80.2734375,\n          60.7421875\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"
