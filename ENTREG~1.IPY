        "    x_val = tabla_resultados[\"Ratio compresión\"].iloc[i]\n",
        "    y_val = tabla_resultados[\"MSE\"].iloc[i]\n",
        "\n",
        "# Colocamos la anotación desplazada un poco (xytext=(5, 5)) para que no tape el punto\n",
        "    plt.annotate(f\"k={k_val}\", (x_val, y_val), textcoords=\"offset points\", xytext=(5, 5), fontsize=9)\n",
        "\n",
        "plt.title(\"MSE vs ratio de compresión\")\n",
        "plt.xlabel(\"Ratio de compresión\")\n",
        "plt.ylabel(\"MSE\")\n",
