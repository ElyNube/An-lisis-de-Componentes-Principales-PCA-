355099458,\n        \"min\": 52.41922755719814,\n        \"max\": 90.62996144464259,\n        \"num_unique_values\": 10,\n        \"samples\": [\n          89.93560544242524,\n          71.14804164782268,\n          86.7576230482777\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"
