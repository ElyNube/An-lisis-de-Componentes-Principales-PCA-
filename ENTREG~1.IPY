75,\n        \"max\": 97.8515625,\n        \"num_unique_values\": 6,\n        \"samples\": [\n          97.8515625,\n          95.8984375,\n          21.6796875\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"
